RewriteEngine On

RewriteCond %{REQUEST_URI} !^/chat/index\.php$
RewriteRule ^(.*)/index\.php$ /$1/ [R=301,L]

# ===== Cache navigateur des ressources statiques =====
<IfModule mod_expires.c>
  ExpiresActive On

  # Images (changent rarement) - 1 an
  ExpiresByType image/jpeg            "access plus 1 year"
  ExpiresByType image/png             "access plus 1 year"
  ExpiresByType image/gif             "access plus 1 year"
  ExpiresByType image/webp            "access plus 1 year"
  ExpiresByType image/svg+xml         "access plus 1 year"
  ExpiresByType image/x-icon          "access plus 1 year"

  # Polices - 1 an
  ExpiresByType font/woff2            "access plus 1 year"
  ExpiresByType font/woff             "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"

  # CSS et JS - 2 jours (souplesse de déploiement pendant les modifs)
  ExpiresByType text/css              "access plus 2 days"
  ExpiresByType application/javascript "access plus 2 days"
  ExpiresByType text/javascript       "access plus 2 days"

  # Par défaut
  ExpiresDefault                      "access plus 2 days"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
  <FilesMatch "\.(woff2?)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=172800"
  </FilesMatch>
</IfModule>
